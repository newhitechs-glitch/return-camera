<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Camera — ระบบจัดการสินค้าส่งคืน</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai+Looped:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #5a0010;
  --red: #c0172b;
  --red-light: #e8203a;
  --red-glow: rgba(192,23,43,0.55);
  --text-w: #ffffff;
  --text-ws: rgba(255,255,255,0.75);
  --text-wm: rgba(255,255,255,0.55);
  --font-display: 'Plus Jakarta Sans', 'IBM Plex Sans Thai Looped', sans-serif;
  --font-body: 'IBM Plex Sans Thai Looped', 'Plus Jakarta Sans', sans-serif;
}
* { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
html, body {
  height: 100%;
  background: #000;
  color: var(--text-w);
  font-family: var(--font-body);
  overflow: hidden;
}

.app {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.cam-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255,255,255,0.08);
  z-index: 10;
}
.cam-header .title {
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 8px;
}
.cam-header .title small {
  display: block;
  font-size: 10px;
  font-weight: 500;
  color: var(--text-ws);
  margin-top: 2px;
  letter-spacing: 0.04em;
}
.cam-header .type-badge {
  display: inline-block;
  padding: 2px 8px;
  background: var(--red);
  border-radius: 99px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.04em;
  margin-left: 6px;
}
.cam-header .close-btn {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.20);
  color: #fff;
  display: grid;
  place-items: center;
  cursor: pointer;
}
.cam-header .close-btn:active { transform: scale(0.92); }

.cam-body {
  flex: 1;
  position: relative;
  background: #000;
  overflow: hidden;
}
#video, #preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
#preview { display: none; }

.cam-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 5;
}
.cam-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(to right, rgba(255,255,255,0.08) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(255,255,255,0.08) 1px, transparent 1px);
  background-size: 33.33% 33.33%;
}

.recording-indicator {
  position: absolute;
  top: 16px;
  left: 50%;
  transform: translateX(-50%);
  display: none;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  background: rgba(220,38,38,0.90);
  border-radius: 99px;
  font-size: 12px;
  font-weight: 700;
  font-family: var(--font-display);
  z-index: 20;
  box-shadow: 0 4px 16px rgba(220,38,38,0.50);
}
.recording-indicator.show { display: flex; }
.recording-indicator .red-dot {
  width: 8px; height: 8px;
  background: #fff;
  border-radius: 50%;
  animation: rec-pulse 1s ease-in-out infinite;
}
@keyframes rec-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}

.cam-loading {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  background: rgba(0,0,0,0.92);
  z-index: 20;
  text-align: center;
}
.spinner {
  width: 48px; height: 48px;
  border: 4px solid rgba(255,255,255,0.20);
  border-top-color: var(--red-light);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 14px;
}
@keyframes spin { to { transform: rotate(360deg); } }

.cam-footer {
  padding: 16px;
  background: rgba(0,0,0,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1px solid rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
  justify-content: space-around;
}

/* Capture button */
.capture-btn {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: #fff;
  border: 5px solid rgba(255,255,255,0.40);
  cursor: pointer;
  transition: all .12s;
  display: grid;
  place-items: center;
  position: relative;
}
.capture-btn::before {
  content: '';
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: #fff;
  border: 2px solid #000;
}
.capture-btn:active { transform: scale(0.92); }
.capture-btn.recording {
  background: var(--red);
}
.capture-btn.recording::before {
  width: 28px;
  height: 28px;
  border-radius: 6px;
  background: #fff;
  border: none;
}

.flip-btn, .gallery-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.22);
  color: #fff;
  display: grid;
  place-items: center;
  cursor: pointer;
  transition: all .15s;
}
.flip-btn:hover, .gallery-btn:hover {
  background: rgba(255,255,255,0.22);
  transform: scale(1.05);
}
.flip-btn:active, .gallery-btn:active { transform: scale(0.94); }

/* Preview mode */
.preview-actions {
  display: none;
  position: absolute;
  inset: 0;
  background: transparent;
  pointer-events: none;
  z-index: 15;
}
.preview-actions.show {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 100px;
  pointer-events: auto;
  background: linear-gradient(to top, rgba(0,0,0,0.50), transparent);
}
.preview-action-bar {
  display: flex;
  gap: 14px;
  align-items: center;
}
.preview-btn {
  padding: 12px 22px;
  border-radius: 99px;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 14px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 7px;
  border: 1px solid;
  transition: all .15s;
}
.preview-btn:active { transform: scale(0.96); }
.btn-retake {
  background: rgba(255,255,255,0.10);
  border-color: rgba(255,255,255,0.30);
  color: #fff;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.btn-retake:hover { background: rgba(255,255,255,0.20); }
.btn-confirm {
  background: linear-gradient(135deg, #4ade80, #16a34a);
  border-color: #4ade80;
  color: #064e3b;
  font-weight: 800;
  box-shadow: 0 6px 20px rgba(34,197,94,0.45);
}
.btn-confirm:hover { filter: brightness(1.05); transform: translateY(-1px); }

.error-msg {
  padding: 16px;
  text-align: center;
  color: #fca5a5;
}

.timer-display {
  position: absolute;
  top: 50px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.65);
  color: #fff;
  padding: 4px 12px;
  border-radius: 99px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  font-weight: 600;
  display: none;
  z-index: 20;
}
.timer-display.show { display: block; }
</style>
</head>
<body>
<div class="app">
  <header class="cam-header">
    <div class="title">
      <div>
        <div id="titleText">กล้อง</div>
        <small>ถ่ายเสร็จกด ✓ จะส่งกลับอัตโนมัติ</small>
      </div>
      <span class="type-badge" id="typeBadge">PHOTO</span>
    </div>
    <button class="close-btn" onclick="closeWindow()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </header>
  
  <div class="cam-body">
    <video id="video" autoplay playsinline muted></video>
    <img id="preview" alt="preview">
    <video id="previewVideo" style="display:none;width:100%;height:100%;object-fit:cover;" controls></video>
    
    <div class="cam-overlay">
      <div class="cam-grid"></div>
    </div>
    
    <div class="recording-indicator" id="recIndicator">
      <span class="red-dot"></span>
      <span id="recTimer">REC 00:00</span>
    </div>
    
    <div class="timer-display" id="timerDisplay">00:00</div>
    
    <div class="cam-loading" id="loadingEl">
      <div>
        <div class="spinner"></div>
        <div style="font-weight:600;">กำลังเปิดกล้อง...</div>
        <small style="opacity:.7;display:block;margin-top:6px;font-size:12px;">กรุณาอนุญาตการใช้กล้อง</small>
      </div>
    </div>
    
    <div class="preview-actions" id="previewActions">
      <div class="preview-action-bar">
        <button class="preview-btn btn-retake" onclick="retake()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M1 20l4.93-4.93A8.5 8.5 0 0 1 20.49 15"/></svg>
          ถ่ายใหม่
        </button>
        <button class="preview-btn btn-confirm" onclick="sendToOpener()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          ใช้รูปนี้
        </button>
      </div>
    </div>
  </div>
  
  <footer class="cam-footer" id="footer">
    <button class="flip-btn" id="flipBtn" title="สลับกล้อง">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><polyline points="16 16 19 19 22 16"/><polyline points="2 8 5 5 8 8"/></svg>
    </button>
    
    <button class="capture-btn" id="captureBtn" title="ถ่าย"></button>
    
    <button class="gallery-btn" id="galleryBtn" title="เลือกจากคลังภาพ">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
    </button>
  </footer>
</div>

<script>
// ===== Parse query params =====
const params = new URLSearchParams(location.search);
const photoType = params.get('type') || 'photo';
const isVideo = photoType === 'video';

const labels = {
  product: 'รูปสินค้า',
  box: 'รูปกล่อง',
  label: 'รูปใบปะหน้า',
  video: 'วิดีโอเปิดกล่อง',
  photo: 'ถ่ายรูป'
};
document.getElementById('titleText').textContent = labels[photoType] || 'ถ่ายรูป';
document.getElementById('typeBadge').textContent = isVideo ? 'VIDEO' : 'PHOTO';

// ===== Camera =====
let stream = null;
let currentFacing = 'environment';
let capturedData = null;
let capturedMime = null;

// Video recording
let mediaRecorder = null;
let recordChunks = [];
let recordStartTime = 0;
let recordTimerId = null;
const MAX_VIDEO_SECONDS = 30;

const video = document.getElementById('video');
const preview = document.getElementById('preview');
const previewVideo = document.getElementById('previewVideo');
const loadingEl = document.getElementById('loadingEl');
const previewActions = document.getElementById('previewActions');
const captureBtn = document.getElementById('captureBtn');
const recIndicator = document.getElementById('recIndicator');
const recTimer = document.getElementById('recTimer');

async function startCamera() {
  try {
    if (stream) {
      stream.getTracks().forEach(t => t.stop());
    }
    const constraints = {
      audio: isVideo,  // เปิดเสียงเมื่อถ่ายวิดีโอ
      video: {
        facingMode: { ideal: currentFacing },
        width: { ideal: 1920 },
        height: { ideal: 1080 }
      }
    };
    stream = await navigator.mediaDevices.getUserMedia(constraints);
    video.srcObject = stream;
    await video.play();
    loadingEl.style.display = 'none';
  } catch (err) {
    loadingEl.innerHTML = '<div class="error-msg"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:block;margin:0 auto 14px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><div style="font-weight:700;font-size:15px;margin-bottom:6px;color:#fca5a5;">ไม่สามารถเปิดกล้องได้</div><small style="opacity:.75;color:#fca5a5;font-size:12px;">' + (err.message || err) + '</small><br><br><button onclick="openFilePicker()" style="margin-top:10px;background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.30);color:#fff;padding:10px 20px;border-radius:10px;cursor:pointer;font-family:inherit;font-weight:600;">เลือกจากคลังภาพแทน</button></div>';
  }
}

// ===== Take photo =====
function takePhoto() {
  const canvas = document.createElement('canvas');
  const w = video.videoWidth;
  const h = video.videoHeight;
  // Resize to max 1280
  const maxSize = 1280;
  let cw = w, ch = h;
  if (w > maxSize || h > maxSize) {
    if (w > h) { ch = (h / w) * maxSize; cw = maxSize; }
    else { cw = (w / h) * maxSize; ch = maxSize; }
  }
  canvas.width = cw;
  canvas.height = ch;
  canvas.getContext('2d').drawImage(video, 0, 0, cw, ch);
  capturedData = canvas.toDataURL('image/jpeg', 0.85);
  capturedMime = 'image/jpeg';
  showPreview('image');
}

// ===== Start video recording =====
function startRecording() {
  recordChunks = [];
  try {
    mediaRecorder = new MediaRecorder(stream, { mimeType: 'video/webm' });
  } catch (e) {
    try { mediaRecorder = new MediaRecorder(stream); }
    catch (e2) { alert('เบราว์เซอร์ไม่รองรับการบันทึกวิดีโอ'); return; }
  }
  
  mediaRecorder.ondataavailable = (e) => {
    if (e.data && e.data.size > 0) recordChunks.push(e.data);
  };
  mediaRecorder.onstop = () => {
    const blob = new Blob(recordChunks, { type: mediaRecorder.mimeType || 'video/webm' });
    const reader = new FileReader();
    reader.onload = () => {
      capturedData = reader.result;
      capturedMime = blob.type;
      showPreview('video');
    };
    reader.readAsDataURL(blob);
  };
  
  mediaRecorder.start();
  recordStartTime = Date.now();
  captureBtn.classList.add('recording');
  recIndicator.classList.add('show');
  
  // Timer
  recordTimerId = setInterval(() => {
    const elapsed = Math.floor((Date.now() - recordStartTime) / 1000);
    const mm = String(Math.floor(elapsed / 60)).padStart(2, '0');
    const ss = String(elapsed % 60).padStart(2, '0');
    recTimer.textContent = 'REC ' + mm + ':' + ss;
    if (elapsed >= MAX_VIDEO_SECONDS) stopRecording();
  }, 200);
}

function stopRecording() {
  if (mediaRecorder && mediaRecorder.state !== 'inactive') {
    mediaRecorder.stop();
  }
  captureBtn.classList.remove('recording');
  recIndicator.classList.remove('show');
  if (recordTimerId) { clearInterval(recordTimerId); recordTimerId = null; }
}

// ===== Show preview =====
function showPreview(kind) {
  if (kind === 'image') {
    video.style.display = 'none';
    preview.style.display = 'block';
    preview.src = capturedData;
    previewVideo.style.display = 'none';
  } else {
    video.style.display = 'none';
    preview.style.display = 'none';
    previewVideo.style.display = 'block';
    previewVideo.src = capturedData;
  }
  document.getElementById('footer').style.display = 'none';
  previewActions.classList.add('show');
}

function retake() {
  capturedData = null;
  capturedMime = null;
  video.style.display = 'block';
  preview.style.display = 'none';
  previewVideo.style.display = 'none';
  previewVideo.src = '';
  document.getElementById('footer').style.display = 'flex';
  previewActions.classList.remove('show');
}

function sendToOpener() {
  if (!capturedData) return;
  if (window.opener && !window.opener.closed) {
    try {
      window.opener.postMessage({
        type: 'photo-capture',
        photoType: photoType,
        mime: capturedMime,
        data: capturedData
      }, '*');
    } catch (e) { console.error(e); }
  }
  setTimeout(closeWindow, 200);
}

function closeWindow() {
  if (stream) { stream.getTracks().forEach(t => t.stop()); }
  if (mediaRecorder && mediaRecorder.state !== 'inactive') { mediaRecorder.stop(); }
  window.close();
  setTimeout(() => {
    document.body.innerHTML = '<div style="padding:40px 20px;text-align:center;color:#fff;font-family:sans-serif;height:100vh;display:grid;place-items:center;background:#000;"><div><div style="font-size:48px;margin-bottom:16px;">✓</div><div style="font-size:18px;font-weight:700;">เสร็จแล้ว</div><div style="opacity:.6;margin-top:10px;font-size:13px;">คุณสามารถปิดแท็บนี้ได้</div></div></div>';
  }, 300);
}

// ===== Capture button =====
captureBtn.addEventListener('click', () => {
  if (isVideo) {
    if (!mediaRecorder || mediaRecorder.state === 'inactive') startRecording();
    else stopRecording();
  } else {
    takePhoto();
  }
});

// ===== Flip camera =====
document.getElementById('flipBtn').addEventListener('click', () => {
  currentFacing = currentFacing === 'environment' ? 'user' : 'environment';
  startCamera();
});

// ===== Gallery (fallback) =====
function openFilePicker() {
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = isVideo ? 'video/*' : 'image/*';
  input.onchange = async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      capturedData = reader.result;
      capturedMime = file.type;
      showPreview(isVideo ? 'video' : 'image');
    };
    reader.readAsDataURL(file);
  };
  input.click();
}
document.getElementById('galleryBtn').addEventListener('click', openFilePicker);

// Start
window.addEventListener('DOMContentLoaded', startCamera);
</script>
</body>
</html>
